pipeline{
	agent any
	stages{
		stage("Cleanup"){
			steps{
				deleteDir()
			}
		}
		
		stage("Clone"){
			steps{
				sh "git clone https://github.com/SWATIPA-GIT-demo/simple-java-maven-app.git"
			}
		}
		
		stage("Build"){
			steps{
				dir("simple-java-maven-app"){
					sh "mvn clean install"
				}
			}
		}
		
		stage("Test"){
			steps{
				dir("simple-java-maven-app"){
					sh "mvn test -Dtest=TestRunner"
				}
			}
		}
	}
}